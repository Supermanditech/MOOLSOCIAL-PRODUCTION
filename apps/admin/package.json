{
  "name": "moolsocial-admin",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3100",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern test-results",
    "test:contracts": "node --test tests/contracts.test.mjs",
    "test:e2e": "playwright test",
    "test": "npm run typecheck && npm run lint && npm run build && npm run test:contracts && npm run test:e2e"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.10",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "type": "module"
}
